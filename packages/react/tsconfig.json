{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": [ "es2022", "DOM" ],
    "jsx": "react-jsx",
    "moduleDetection": "force",
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict":  false
  },
  "include": [ "src/**/*.ts" ],
  "exclude": []
}